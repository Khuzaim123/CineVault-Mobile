{
  "expo": {
    "name": "CineVault",
    "slug": "CineVaultApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "cinevaultapp",
    "userInterfaceStyle": "dark",
    "ios": {
      "bundleIdentifier": "com.cinevault.app",
      "supportsTablet": false
    },
    "android": {
      "package": "com.cinevault.app",
      "backgroundColor": "#07080F",
      "adaptiveIcon": {
        "backgroundColor": "#07080F",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-video",
      [
        "expo-image-picker",
        {
          "photosPermission": "CineVault needs access to your photos to set your profile picture.",
          "cameraPermission": "CineVault needs camera access to take a profile photo."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#07080F",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "699e122e-4380-4fe1-a091-047684bc6abe"
      }
    }
  }
}
